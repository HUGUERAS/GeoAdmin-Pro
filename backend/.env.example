# ==========================================
# GEOADMIN PRO - ENVIRONMENT CONFIGURATION
# ==========================================

# ------------------------------------------
# SUPABASE CONFIGURATION
# ------------------------------------------
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1Ni...
# O backend necessita de Service Role Key para ignorar RLS nas rotas internas
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1Ni...

# ------------------------------------------
# AI & AGENTS (LLM)
# ------------------------------------------
ANTHROPIC_API_KEY=sk-ant-api03...

# ------------------------------------------
# API SERVER SETTINGS
# ------------------------------------------
API_SERVER_HOST=0.0.0.0
API_SERVER_PORT=8000
CORS_ORIGINS=http://localhost:3000,http://localhost:8081
LOG_LEVEL=INFO
AUTH_OBRIGATORIO=true

# ------------------------------------------
# REALTIME & WEBSOCKETS
# ------------------------------------------
REALTIME_ENABLED=true
WEBSOCKET_HEARTBEAT_SECONDS=30

# ------------------------------------------
# MESSAGING & CHANNELS (HERMES / WHATSAPP)
# ------------------------------------------
# Controla se a integração externa está ativa
EXTERNAL_MESSAGES_ENABLED=true

# DRY-RUN: Se true, as mensagens são persistidas mas não chamam APIs de terceiros.
# MANDATÓRIO SER TRUE EM DESENVOLVIMENTO
WHATSAPP_DRY_RUN=true
HERMES_DRY_RUN=true

# WORKFLOW DE APROVAÇÃO
REQUIRE_HUMAN_APPROVAL=true
AUTO_REPLY_INBOUND=false

# ------------------------------------------
# WEBHOOKS (RECEBIMENTO INBOUND)
# ------------------------------------------
WEBHOOKS_ENABLED=true
HERMES_WEBHOOK_SECRET=hermes_secret_mock
WHATSAPP_WEBHOOK_SECRET=whatsapp_secret_mock
