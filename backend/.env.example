# Copie este arquivo para .env e preencha os valores reais.
#
# ⚠️  CHAVES DO SUPABASE — USE AS CORRETAS:
#   - SUPABASE_KEY aqui é a  SERVICE ROLE KEY  (começa com "eyJ...")
#     → Acesso total ao banco, bypassa RLS. NUNCA expor no client-side.
#   - O mobile NÃO usa chave Supabase diretamente; acessa tudo via backend.
#   - Para referência: a ANON KEY (usada em clients públicos) fica em
#     mobile/constants se o app precisar autenticar via Supabase Auth.

SUPABASE_URL=https://jrlrlsotwsiidglcbifo.supabase.co
SUPABASE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...service_role_key_aqui

# URL pública do backend (Railway, Render, etc.)
# Usada nos magic links enviados por WhatsApp.
APP_URL=https://seu-backend-publico.railway.app

# Origens CORS permitidas (separadas por vírgula)
# Em prod, coloque apenas o domínio do frontend.
# Em dev, os valores padrão de localhost já são usados automaticamente.
ALLOWED_ORIGINS=https://geoadmin-pro.vercel.app,http://localhost:8081,http://localhost:19006

# ── Recursos locais do LandStar (D:\coletoraprolanddd\outras biblioteecas) ────

# Pasta com os modelos de geoide IBGE (hgeoHNOR_2020.gsf, sa2010.grd)
# Usado em POST /geo/altitude/corrigir
GEOID_DIR=D:\coletoraprolanddd\outras biblioteecas\Geoid

# Banco de dados PROJ para conversões CRS offline (SIRGAS2000, UTM, WGS84)
# Contém proj.db com todas as definições EPSG sem precisar de internet
PROJ_DATA=D:\coletoraprolanddd\outras biblioteecas\proj

