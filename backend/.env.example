# ─── Vertex: Nomes Oficiais de Ambiente (Contrato de Arquitetura) ──────────────
# Documentação: docs/arquitetura.md

APP_ENV=development
ALLOWED_ORIGINS=http://localhost:8081,http://127.0.0.1:8081,http://localhost:8000
PUBLIC_APP_URL=http://localhost:8000

# ─── Supabase ───────────────────────────────────────────────
SUPABASE_URL=https://SEU_PROJECT_ID.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_JWT_SECRET=seu-jwt-secret
# Compatibilidade legada: deployments antigos podem usar SUPABASE_KEY.
# Preferir SUPABASE_ANON_KEY + SUPABASE_SERVICE_ROLE_KEY em novos ambientes.
# SUPABASE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Storage bucket (criado manualmente no painel Supabase)
SUPABASE_BUCKET_ARQUIVOS_PROJETO=arquivos-projeto

# ─── Autenticação ────────────────────────────────────────────
# "true" em produção, "false" para dev local sem token
AUTH_OBRIGATORIO=true

# ─── Deploy (preenchido automaticamente pela plataforma) ──────────
# PORT=8000

# ─── Integração VERTEXROSEA (CAD Engine) ────────────────────────
VERTEXROSEA_API_URL=http://localhost:8001
VERTEXROSEA_API_KEY=local_integration_secret_token

