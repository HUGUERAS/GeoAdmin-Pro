# Nunca versionar credenciais locais (.env.example é versionado propositalmente)
.env
.env.*
!.env.example

# Artefatos locais de Python
__pycache__/
*.py[cod]

# Fallback local temporario da geometria de referencia
data/geometrias_referencia_cliente.json
# Logs locais do servidor
*.log
logs/

# Type checkers / linters
.mypy_cache/
.ruff_cache/

# Build / dist
build/
dist/
*.egg-info/

# Fallback local de areas
data/areas_projeto.json

